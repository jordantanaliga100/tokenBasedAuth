# /client/Dockerfile.dev
FROM node:20-alpine

WORKDIR /app

# Copy package files muna para sa caching ng layers
COPY package.json pnpm-lock.yaml* ./

# Install pnpm (dahil pnpm ang gamit mo sa backend, gawin nating uniform)
RUN npm install -g pnpm && pnpm install

# Copy ang buong source code
COPY . .

# I-expose ang Vite port
EXPOSE 5173

# Patakbuhin ang Vite sa host mode para makita ng Nginx
CMD ["pnpm", "run", "dev", "--host"]